# Copy to .env and fill in (never commit .env).

# https://fireworks.ai/ — OpenAI-compatible API at FIREWORKS_BASE_URL
FIREWORKS_API_KEY=

# Alder MCP — same Bearer token as in Cursor MCP config for https://api.alder.so/mcp
ALDER_API_KEY=

# Directory for read_file_lines / edit_file / bash (defaults: CLI arg → cwd).
# Example: RESEARCH_WORKSPACE=/path/to/repo
# RESEARCH_WORKSPACE=

# Optional overrides
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
# ALDER_MCP_URL=https://api.alder.so/mcp
